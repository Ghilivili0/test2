# Copy this file to .env for local development.
# On Railway, set these under your service's "Variables" tab instead —
# do not commit a real .env file.

# Your bot's API token, generated on the Highrise website under
# Settings > Bots.
HIGHRISE_BOT_TOKEN=your-bot-token-here

# The room ID the bot should join. Get this from the room's
# "Share this Room" link in the Highrise app. The bot account needs
# designer rights in that room.
HIGHRISE_ROOM_ID=your-room-id-here

# Optional: customize the welcome message. {username} is replaced
# with the new user's name.
WELCOME_MESSAGE=Welcome to the room, {username}! Type !help to see what I can do.

# Optional: where the admin list JSON file is stored. If unset, it
# defaults to ./data/admins.json. On Railway, point this at a path
# inside an attached Volume if you want the admin list to survive
# redeploys, e.g. /data/admins.json
# ADMIN_STORE_PATH=./data/admins.json
